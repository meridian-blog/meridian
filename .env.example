# =============================================================================
# Meridian Blog Engine - Environment Variables
# Copy this file to .env and update the values.
# =============================================================================

# -----------------------------------------------------------------------------
# DEVELOPMENT DEFAULTS (safe for local use)
# -----------------------------------------------------------------------------

# Admin account created on first migration
ADMIN_EMAIL=admin@meridian.blog
ADMIN_PASSWORD=changeme123
ADMIN_NAME=Admin

# Application
APP_ENV=development
APP_PORT=8000
APP_DOMAIN=localhost:8000
APP_SECRET=change-this-to-a-random-string-at-least-32-chars

# Database
POSTGRES_PASSWORD=meridian_secret
DATABASE_URL=postgres://meridian:meridian_secret@localhost:5432/meridian

# Redis (no password required in dev)
REDIS_PASSWORD=

# Stripe (optional - needed for paid subscriptions)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Email (optional - needed for newsletters)
# EMAIL_PROVIDER=resend
# EMAIL_API_KEY=re_...
# EMAIL_FROM=newsletter@yourdomain.com

# =============================================================================
# PRODUCTION — You MUST change every value marked [REQUIRED] before going live.
# Leaving default secrets in production is a critical security risk.
# =============================================================================
#
# [REQUIRED] ADMIN_EMAIL       — Set to your real email address.
# [REQUIRED] ADMIN_PASSWORD    — Use a strong, unique password (20+ chars).
# [REQUIRED] APP_SECRET        — Random string, minimum 32 characters.
#                                 Generate one:  openssl rand -base64 48
# [REQUIRED] APP_DOMAIN        — Your public domain (e.g. blog.example.com).
#                                 Used by Caddy for automatic HTTPS via Let's Encrypt.
#                                 Ports 80 and 443 must be open on the server.
# [REQUIRED] POSTGRES_PASSWORD — Strong database password.
#                                 Generate one:  openssl rand -base64 32
# [REQUIRED] REDIS_PASSWORD    — Strong Redis password.
#                                 Generate one:  openssl rand -base64 32
# [REQUIRED] APP_ENV           — Set to "production".
#
# Recommended production values:
#
#   APP_ENV=production
#   APP_DOMAIN=blog.example.com
#   APP_SECRET=<output of: openssl rand -base64 48>
#   POSTGRES_PASSWORD=<output of: openssl rand -base64 32>
#   REDIS_PASSWORD=<output of: openssl rand -base64 32>
#   ADMIN_EMAIL=you@example.com
#   ADMIN_PASSWORD=<strong unique password>
#
# To start in production mode:
#   docker compose --profile production up -d
#
# To run migrations (do this once before first start, and after updates):
#   docker compose --profile production run --rm app-prod \
#     deno run --allow-net --allow-read --allow-env db/migrate.ts
# =============================================================================
